{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build:cli",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "-f",
                "net10.0",
                "${workspaceFolder}/Shoko.CLI/Shoko.CLI.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build:tray-service",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "-f",
                "net10.0",
                "${workspaceFolder}/Shoko.TrayService/Shoko.TrayService.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/Shoko.CLI/Shoko.CLI.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "${workspaceFolder}/Shoko.CLI/Shoko.CLI.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        }
    ],
}
